root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{swift,h,m,mm,c,cpp,hpp}]
indent_style = space
indent_size = 4

[*.rb]
indent_style = space
indent_size = 2

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[*.{sh,bash}]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

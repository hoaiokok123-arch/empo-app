#!/bin/sh
# Pre-commit hook: lint + format the staged files.
#
# Mirrors the file-type scopes the GitHub Actions Lint + Format
# workflows enforce (.github/workflows/lint.yml, format.yml) so a
# clean local commit translates to a green CI run.
#
# Each tool block is gated on whether the staged set actually
# contains files in its scope; touching only Markdown skips Swift,
# touching only Swift skips clang-format, etc. Missing tools log a
# warning and skip rather than failing the commit; CI remains the
# authoritative gate.
#
# Auto-fixers (formatters) rewrite files in-place and re-stage them
# so the resulting commit always matches the formatter's output.
# Linters that can't auto-fix print their report and abort the
# commit so the contributor can address the issue and re-run.
#
# Skip the hook for an emergency commit with `git commit --no-verify`.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Staged files we care about: added / copied / modified / renamed.
# Deletions, type changes, and unmerged paths are filtered out so
# we don't ask a formatter to read a path that no longer exists.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
    exit 0
fi

# Filter STAGED with an extended regex; emits matching lines or
# nothing. Callers wrap the result in `if [ -n "$x" ]` to gate the
# rest of the block.
match() {
    echo "$STAGED" | grep -E "$1" || true
}

# Add a list of files (one per line) back to the index after a
# formatter rewrote them. Skips empty input so `git add` doesn't
# error on no args.
restage() {
    [ -z "$1" ] && return 0
    echo "$1" | xargs git add
}

# Print a section header so the hook output stays readable when
# multiple tools run for one commit.
section() {
    printf '\n→ %s\n' "$1"
}

# Mark the commit as failed with a clear pointer at which tool
# rejected it. Gives the contributor a single line to grep for in
# the post-mortem.
die() {
    printf '\n✗ pre-commit: %s\n' "$1" >&2
    exit 1
}

# Tool-presence helper. Pre-commit is best-effort; if a tool isn't
# installed locally we want a soft warning rather than a hard
# failure (CI still enforces). Returns 0 when present, 1 when not.
have() {
    command -v "$1" >/dev/null 2>&1
}

# 1. Swift -- swift-format (formatter + lint), swiftlint (lint).
#
# swift-format does both: `format -i` rewrites in place and `lint
# --strict` mirrors what CI runs. We rewrite first, re-stage, then
# lint so the user sees the same diagnostics CI would.
SWIFT_FILES=$(match '^ios/Empo/src/.*\.swift$')
if [ -n "$SWIFT_FILES" ]; then
    section "swift-format (Swift)"
    if have swift-format; then
        echo "$SWIFT_FILES" | xargs swift-format format -i
        restage "$SWIFT_FILES"
        echo "$SWIFT_FILES" | xargs swift-format lint --strict \
            || die "swift-format lint failed"
    else
        echo "  (skipped: swift-format not installed; brew install swift-format)"
    fi

    section "swiftlint (Swift)"
    if have swiftlint; then
        # SwiftLint defaults to scanning the whole project; pass
        # explicit paths so the hook only checks what's staged.
        # shellcheck disable=SC2086 # we want word-splitting on file list
        swiftlint lint --strict --quiet $SWIFT_FILES \
            || die "swiftlint failed"
    else
        echo "  (skipped: swiftlint not installed; brew install swiftlint)"
    fi
fi

# 2. ObjC / C / C++ -- clang-format (formatter only; no separate
# linter in CI).
CPP_FILES=$(match '^ios/Empo/(src|shims)/.*\.(h|m|mm|c|cpp)$')
if [ -n "$CPP_FILES" ]; then
    section "clang-format (ObjC / C / C++)"
    if have clang-format; then
        echo "$CPP_FILES" | xargs clang-format -i
        restage "$CPP_FILES"
    else
        echo "  (skipped: clang-format not installed; brew install clang-format)"
    fi
fi

# 3. Shell -- shfmt (formatter), shellcheck (lint).
#
# CI scope is `tools/*.sh`; mirror that. Hooks under `.githooks/`
# are intentionally excluded (POSIX `sh`, not Bash) since shfmt's
# default would impose Bash-only conventions on them.
SH_FILES=$(match '^tools/.*\.sh$')
if [ -n "$SH_FILES" ]; then
    section "shfmt + shellcheck (Bash)"
    if have shfmt; then
        echo "$SH_FILES" | xargs shfmt -w -i 4 -ci
        restage "$SH_FILES"
    else
        echo "  (skipped: shfmt not installed; brew install shfmt)"
    fi

    if have shellcheck; then
        echo "$SH_FILES" | xargs shellcheck || die "shellcheck failed"
    else
        echo "  (skipped: shellcheck not installed; brew install shellcheck)"
    fi
fi

# 4. YAML / JSON -- prettier (formatter only).
#
# Mirrors CI's narrow scope: project.yml + the curated game
# registry. Other YAML/JSON files (workflows, asset catalogs)
# follow their own conventions and aren't gated.
PRETTIER_FILES=$(match '^(ios/Empo/project\.yml|ios/Empo/curated-patches/gameRegistry\.json)$')
if [ -n "$PRETTIER_FILES" ]; then
    section "prettier (YAML / JSON)"
    if have bun; then
        echo "$PRETTIER_FILES" | xargs bun x prettier --write
        restage "$PRETTIER_FILES"
    else
        echo "  (skipped: bun not installed; brew install oven-sh/bun/bun)"
    fi
fi

# 5. Markdown -- markdownlint (lint only; no autofix in CI).
MD_FILES=$(match '\.md$')
if [ -n "$MD_FILES" ]; then
    section "markdownlint (Markdown)"
    if have bun; then
        echo "$MD_FILES" | xargs bun x markdownlint -c .markdownlint.json \
            || die "markdownlint failed"
    else
        echo "  (skipped: bun not installed; brew install oven-sh/bun/bun)"
    fi
fi

printf '\n✓ pre-commit OK\n'

#!/bin/sh
# Post-commit hook: regenerate GitInfo.generated.swift with the new commit hash.
# This keeps the version display accurate regardless of IDE.

REPO_ROOT="$(git rev-parse --show-toplevel)"
OUT="$REPO_ROOT/ios/Empo/src/App/GitInfo.generated.swift"

COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
DIRTY="false"

cat > "$OUT" <<EOF
// Auto-generated by git post-commit hook — do not edit
enum GitInfo {
    static let commit = "$COMMIT"
    static let dirty = $DIRTY
}
EOF

# Games (large, user-provided content)
demo/games/

# Build artifacts
ios/Empo/build/
ios/Empo/Empo.xcodeproj/
*.ipa

# Dependencies (downloaded sources and build outputs)
ios/Dependencies/downloads/
ios/Dependencies/build-*/

# ANGLE prebuilt - hydrated at build time by tools/fetch-angle.sh
# from a tagged release on github.com/mateo-m/empo-deps. The binaries
# are too large for git (~80 MB) and version-pinned via
# ios/Dependencies/ANGLE/.version (which IS tracked).
ios/Dependencies/ANGLE/iphoneos/include/
ios/Dependencies/ANGLE/iphoneos/lib/
ios/Dependencies/ANGLE/iphonesimulator/include/
ios/Dependencies/ANGLE/iphonesimulator/lib/
ios/Dependencies/ANGLE/.fetched-version

# MetalANGLE.xcframework - unreferenced by the build, kept untracked
# in case anything ever needs it. Currently not in the working tree.
ios/Dependencies/Frameworks/

# Xcode / DerivedData
DerivedData/
*.xcworkspace
xcuserdata/

# Clangd / LSP cache
.cache/
compile_commands.json

# macOS
.DS_Store
**/.DS_Store

# Temporary files
*.swp
*.swo
*~
ios/Empo/src/App/GitInfo.generated.swift

*.md
!/docs/**/*.md
!/ios/**/*.md
!/README.md

# Python cache (agent skill scripts)
__pycache__/
*.pyc

# Per-contributor code signing config (see Signing.xcconfig.example)
ios/Empo/Signing.xcconfig

# Assets.bundle is assembled at build time from engine submodule sources.
# Only .gitkeep is tracked to preserve the directory.
ios/Empo/Assets.bundle/*
!ios/Empo/Assets.bundle/.gitkeep
# Node tool caches (CI uses bun + bun.lock instead).
node_modules/

# Build outputs (xcodebuild derived data, IPA artifacts).
build/
